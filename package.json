    "eslint-plugin-simple-import-sort": "^13.0.0",
    "extract-zip": "^2.0.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "i18next-scanner": "^4.6.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.9.5",
    "prettier-eslint": "^17.1.1",
    "process": "^0.11.10",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "vite": "^8.1.4",
    "vite-plugin-static-copy": "^4.1.1",
    "vite-plugin-svgr": "^5.2.0"
  }
